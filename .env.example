# Copy to .env and fill in. NEVER commit .env (see /secrets-check).

# Postgres — compose default; override for external DBs
DATABASE_URL=postgresql://octo:octo@localhost:5432/octo

# Executor auth — fill the one(s) you use (agents pick via their manifest's `executor:` field)
# claude-sdk executor:
ANTHROPIC_API_KEY=sk-ant-REPLACE-ME
# openrouter executor (free-tier models work — pick a :free model):
OPENROUTER_API_KEY=sk-or-REPLACE-ME
# OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Static bearer token for the API — generate your own (e.g. `openssl rand -hex 24`)
OCTO_API_TOKEN=change-me

# Where the CLI finds the API
OCTO_API_URL=http://localhost:8000

OCTO_ENV=local
LOG_LEVEL=info
WORKER_CONCURRENCY=1
SCHEDULER_ENABLED=true
